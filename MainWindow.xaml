<Window x:Class="RSA.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:RSA"
        Title="RSA Криптосистема" Height="950" Width="1100" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:TagToBoolConverter x:Key="TagToBoolConverter"/>

        <!-- Стиль для анимированного текста с точками -->
        <Style x:Key="AnimatedTextStyle" TargetType="TextBlock">
            <Setter Property="Text" Value="Генерация"/>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <StringAnimationUsingKeyFrames 
                                Storyboard.TargetProperty="Text" 
                                Duration="0:0:3">
                                <DiscreteStringKeyFrame KeyTime="0:0:0.0" Value="Генерация"/>
                                <DiscreteStringKeyFrame KeyTime="0:0:0.5" Value="Генерация."/>
                                <DiscreteStringKeyFrame KeyTime="0:0:1.0" Value="Генерация.."/>
                                <DiscreteStringKeyFrame KeyTime="0:0:1.5" Value="Генерация..."/>
                                <DiscreteStringKeyFrame KeyTime="0:0:2.0" Value="Генерация.."/>
                                <DiscreteStringKeyFrame KeyTime="0:0:2.5" Value="Генерация."/>
                                <DiscreteStringKeyFrame KeyTime="0:0:3.0" Value="Генерация"/>
                            </StringAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Затемняющий слой и индикатор загрузки (поверх всего) -->
        <Grid x:Name="LoadingOverlay" Grid.RowSpan="3" Background="#80000000" Visibility="Collapsed" Panel.ZIndex="1000">
            <Grid Width="300" Height="120" Background="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                    <TextBlock x:Name="LoadingText" Style="{StaticResource AnimatedTextStyle}" 
                               FontSize="18" FontWeight="Bold" Foreground="#FF007ACC" 
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <ProgressBar Width="200" Height="10" IsIndeterminate="True" Foreground="#FF007ACC" Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Заголовок -->
        <TextBlock Text="RSA Криптосистема" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10" Grid.Row="0"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="5">
                <!-- Генерация ключей -->
                <GroupBox Header="Генерация ключей" Margin="0,0,0,10">
                    <StackPanel Margin="10">
                        <TextBlock Text="Выберите размер (b) для простых чисел:" Margin="0,5" FontWeight="Bold"/>
                        <TextBlock Text="p = b-1 бит, q = b бит" Margin="0,0,0,5" FontStyle="Italic"/>

                        <ComboBox x:Name="cmbBitSize" Margin="5" SelectionChanged="cmbBitSize_SelectionChanged">
                            <ComboBoxItem Content="8 бит (p=7 бит, q=8 бит)" Tag="8"/>
                            <ComboBoxItem Content="16 бит (p=15 бит, q=16 бит)" Tag="16"/>
                            <ComboBoxItem Content="32 бита (p=31 бит, q=32 бита)" Tag="32"/>
                            <ComboBoxItem Content="64 бита (p=63 бита, q=64 бита)" Tag="64"/>
                            <ComboBoxItem Content="128 бит (p=127 бит, q=128 бит)" Tag="128" IsSelected="True"/>
                            <ComboBoxItem Content="256 бит (p=255 бит, q=256 бит)" Tag="256"/>
                            <ComboBoxItem Content="512 бит (p=511 бит, q=512 бит)" Tag="512"/>
                            <ComboBoxItem Content="1024 бита (p=1023 бита, q=1024 бита)" Tag="1024"/>
                        </ComboBox>

                        <TextBlock Text="Автоматическая генерация простых чисел указанного размера" FontStyle="Italic" Margin="0,5"/>

                        <Grid Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="p (b-1 бит):" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox x:Name="txtPDisplay" Grid.Row="0" Grid.Column="1" Margin="5" IsReadOnly="True" Background="#FFF0F0F0" TextWrapping="Wrap" Height="60"/>

                            <TextBlock Text="q (b бит):" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox x:Name="txtQDisplay" Grid.Row="1" Grid.Column="1" Margin="5" IsReadOnly="True" Background="#FFF0F0F0" TextWrapping="Wrap" Height="60"/>
                        </Grid>

                        <Separator Margin="0,10"/>

                        <TextBlock Text="Публичная экспонента e:" Margin="0,5"/>
                        <TextBox x:Name="txtE" Text="65537" Margin="5" IsEnabled="False" MaxLength="10"/>

                        <Button x:Name="btnGenerateKeys" Content="Сгенерировать ключи" Padding="10" Margin="5" Height="40" FontSize="14" FontWeight="Bold" Click="btnGenerateKeys_Click"/>
                    </StackPanel>
                </GroupBox>

                <!-- Сгенерированные ключи -->
                <GroupBox Header="Сгенерированные ключи" Margin="0,0,0,10">
                    <StackPanel Margin="10">
                        <TextBlock Text="Открытый ключ (n, e):" FontWeight="Bold" Margin="0,5"/>
                        <TextBox x:Name="txtPublicKey" TextWrapping="Wrap" Height="60" IsReadOnly="True" Margin="5" Background="#FFF0F0F0"/>

                        <TextBlock Text="Закрытый ключ (d):" FontWeight="Bold" Margin="0,5"/>
                        <TextBox x:Name="txtPrivateKey" TextWrapping="Wrap" Height="60" IsReadOnly="True" Margin="5" Background="#FFF0F0F0"/>

                        <Expander Header="Дополнительные параметры" IsExpanded="True">
                            <StackPanel>
                                <TextBlock Text="λ(n):" Margin="0,5" FontWeight="Bold"/>
                                <TextBox x:Name="txtLambda" TextWrapping="Wrap" Height="40" IsReadOnly="True" Margin="5" Background="#FFF0F0F0"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </GroupBox>

                <!-- Исходное сообщение -->
                <GroupBox Header="Исходное сообщение" Margin="0,0,0,10">
                    <StackPanel Margin="10">
                        <RadioButton x:Name="rbTextMessage" Content="Текстовое сообщение" IsChecked="True" Margin="5" Checked="RadioButton_Checked"/>
                        <TextBox x:Name="txtMessage" TextWrapping="Wrap" Height="60" Margin="5,0,5,5" Text="Hello, RSA!" 
                                 IsEnabled="{Binding ElementName=rbTextMessage, Path=IsChecked}"
                                 TextChanged="txtMessage_TextChanged"/>

                        <RadioButton x:Name="rbNumberMessage" Content="Числовое сообщение" Margin="5" Checked="RadioButton_Checked"/>
                        <TextBox x:Name="txtNumberMessage" Text="65" Margin="5,0,5,5" 
                                 IsEnabled="{Binding ElementName=rbNumberMessage, Path=IsChecked}"
                                 TextChanged="txtNumberMessage_TextChanged"
                                 PreviewTextInput="NumberOnly_PreviewTextInput"
                                 MaxLength="50"/>
                    </StackPanel>
                </GroupBox>

                <!-- Параметры подписи -->
                <GroupBox Header="Параметры подписи" Margin="0,0,0,10">
                    <StackPanel Margin="10">
                        <TextBlock Text="Выберите алгоритм хэширования:" Margin="0,5" FontWeight="Bold"/>
                        <ComboBox x:Name="cmbHashAlgorithm" Margin="5" SelectionChanged="cmbHashAlgorithm_SelectionChanged">
                            <ComboBoxItem Content="SHA-1" Tag="SHA1"/>
                            <ComboBoxItem Content="SHA-256" Tag="SHA256" IsSelected="True"/>
                            <ComboBoxItem Content="SHA-384" Tag="SHA384"/>
                            <ComboBoxItem Content="SHA-512" Tag="SHA512"/>
                            <ComboBoxItem Content="ID пользователя (не выбрано)" Tag="USER_ID"/>
                        </ComboBox>
                        <TextBlock Text="Если алгоритм не выбран, используется ID пользователя" FontSize="10" FontStyle="Italic" Margin="5,0"/>

                        <Grid Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="ID пользователя:" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtUserId" Grid.Column="1" Margin="5" Text="12345" 
                                     IsEnabled="{Binding ElementName=cmbHashAlgorithm, Path=SelectedItem, Converter={StaticResource TagToBoolConverter}}"
                                     PreviewTextInput="NumberOnly_PreviewTextInput"
                                     MaxLength="7"/>
                            <Button x:Name="btnGenerateUserId" Grid.Column="2" Content="Сгенерировать" Margin="5" Padding="10,2" 
                                    Click="btnGenerateUserId_Click" 
                                    IsEnabled="{Binding ElementName=cmbHashAlgorithm, Path=SelectedItem, Converter={StaticResource TagToBoolConverter}}"/>
                        </Grid>

                        <TextBlock Text="ID генерируется от 1 до 1 000 000 (только цифры)" FontSize="10" FontStyle="Italic" Margin="5,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- Кнопки действий -->
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btnEncryptAndSign" Grid.Column="0" Content="Зашифровать и подписать" Padding="10" Margin="5" Height="40" FontWeight="Bold" Click="btnEncryptAndSign_Click" IsEnabled="False"/>
                    <Button x:Name="btnVerifyAndDecrypt" Grid.Column="1" Content="Проверить подпись и расшифровать" Padding="10" Margin="5" Height="40" FontWeight="Bold" Click="btnVerifyAndDecrypt_Click" IsEnabled="False"/>
                </Grid>

                <!-- Результаты -->
                <GroupBox Header="Результат" Margin="0,10">
                    <StackPanel Margin="10">
                        <TextBlock Text="Зашифрованное сообщение (c):" FontWeight="Bold" Margin="0,5"/>
                        <TextBox x:Name="txtCiphertext" TextWrapping="Wrap" Height="60" IsReadOnly="True" Margin="5" Background="#FFF0F0F0"/>

                        <TextBlock Text="Цифровая подпись (s):" FontWeight="Bold" Margin="0,5"/>
                        <TextBox x:Name="txtSignature" TextWrapping="Wrap" Height="60" Margin="5" Background="#FFF0F0F0" TextChanged="txtSignature_TextChanged"/>

                        <TextBlock Text="Информация о подписи/хеше:" FontWeight="Bold" Margin="0,5"/>
                        <TextBox x:Name="txtHashDisplay" TextWrapping="Wrap" Height="40" Margin="5" IsReadOnly="True" FontFamily="Consolas" FontSize="10" Background="#FFF0F0F0"/>

                        <TextBlock Text="Расшифрованное сообщение:" FontWeight="Bold" Margin="0,5"/>
                        <TextBox x:Name="txtDecrypted" TextWrapping="Wrap" Height="60" IsReadOnly="True" Margin="5" Background="#FFF0F0F0"/>

                        <TextBlock x:Name="txtSignResult" TextWrapping="Wrap" Height="30" Margin="5" FontWeight="Bold"/>
                        <TextBlock x:Name="txtSignatureStatus" TextWrapping="Wrap" Height="30" Margin="5" FontWeight="Bold"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Строка состояния -->
        <StatusBar Grid.Row="2" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="Готово"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>